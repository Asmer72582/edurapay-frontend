# Copy to .env.local for local dev, or set in Vercel → Project → Settings → Environment Variables

# Public site URL (SEO canonical, Open Graph, sitemap — use your production domain)
VITE_SITE_URL=https://www.edurapay.in

# Backend API (dashboard / app login — not required for demo form)
VITE_API_BASE_URL=http://localhost:8000/api

# EmailJS — demo & contact form (https://www.emailjs.com)
# Create a service + template; use these template variables:
# from_name, from_email, reply_to, phone, institute, subject, message, request_type
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
